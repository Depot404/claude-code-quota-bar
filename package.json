{
  "name": "claude-code-quota-bar",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "2.21.6",
  "publisher": "AnthonyDame",
  "license": "MIT",
  "icon": "images/icon.png",
  "author": {
    "name": "Anthony Dame"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Depot404/claude-code-quota-bar"
  },
  "bugs": {
    "url": "https://github.com/Depot404/claude-code-quota-bar/issues"
  },
  "homepage": "https://github.com/Depot404/claude-code-quota-bar#readme",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "quota",
    "usage",
    "usage tracker",
    "conversations",
    "conversation manager",
    "sidebar",
    "anthropic",
    "notifications",
    "sound",
    "burn rate",
    "context window",
    "focus window"
  ],
  "galleryBanner": {
    "color": "#1F1F1F",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "claudeCodeQuotaBar",
          "title": "%viewContainer.title%",
          "icon": "images/panel-icon.svg"
        }
      ]
    },
    "views": {
      "claudeCodeQuotaBar": [
        {
          "id": "claudeCodeQuotaBar.panel",
          "name": "%view.name%",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "claude-code-quota-bar.open",
        "title": "%command.open.title%"
      },
      {
        "command": "claude-code-quota-bar.refresh",
        "title": "%command.refresh.title%"
      },
      {
        "command": "claude-code-quota-bar.installHooks",
        "title": "%command.installHooks.title%"
      },
      {
        "command": "claude-code-quota-bar.showPanel",
        "title": "%command.showPanel.title%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "claudeCodeQuotaBar.refreshIntervalMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 120,
          "description": "%config.refreshIntervalMinutes.description%"
        },
        "claudeCodeQuotaBar.burnRateGreenMax": {
          "type": "number",
          "default": 0.85,
          "minimum": 0,
          "description": "%config.burnRateGreenMax.description%"
        },
        "claudeCodeQuotaBar.burnRateYellowMax": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "description": "%config.burnRateYellowMax.description%"
        },
        "claudeCodeQuotaBar.sounds.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.sounds.enabled.description%"
        },
        "claudeCodeQuotaBar.braveUserDataDir": {
          "type": "string",
          "default": "",
          "description": "%config.braveUserDataDir.description%"
        },
        "claudeCodeQuotaBar.conversationSortOrder": {
          "type": "string",
          "enum": [
            "tabOrder",
            "lastActivity",
            "statusFirst"
          ],
          "enumDescriptions": [
            "%config.conversationSortOrder.enum.tabOrder%",
            "%config.conversationSortOrder.enum.lastActivity%",
            "%config.conversationSortOrder.enum.statusFirst%"
          ],
          "default": "tabOrder",
          "description": "%config.conversationSortOrder.description%"
        },
        "claudeCodeQuotaBar.collapsedConversations": {
          "type": "boolean",
          "default": false,
          "description": "%config.collapsedConversations.description%"
        },
        "claudeCodeQuotaBar.collapsedQuota": {
          "type": "boolean",
          "default": false,
          "description": "%config.collapsedQuota.description%"
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  },
  "l10n": "./l10n"
}
